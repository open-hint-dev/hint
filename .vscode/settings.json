{
    "[env]": {
        "editor.formatOnSave": false
    },
    "[ignore]": {},
    "[shellscript]": {
        "editor.defaultFormatter": "foxundermoon.shell-format"
    },
    "cSpell.customDictionaries": {
        "custom": true,
        "project-words": {
            "addWords": true,
            "description": "Words used in this project",
            "name": "project-words",
            "path": "${workspaceRoot}/cspell.txt"
        }
    },
    "editor.codeActionsOnSave": {
        "source.removeUnusedImports": "always"
    },
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "explorerExclude.backup": {},

    "files.associations": {
        "*.hint": "markdown"
    },

    "files.exclude": {
        "**/.git": false,
        "**/.svn": false,
        "**/.hg": false,
        "**/.DS_Store": false,
        "**/Thumbs.db": false,
        "**/.classpath": false,
        "**/.factorypath": false,
        "**/.project": false,
        "**/.settings": false,
        "**/.prettierignore": false,
        "**/.turbo": false,
        "**/.venv": false,
        "**/.vscode": false,
        "**/.yarn": false,
        "**/.yarnrc": false,
        "**/.yarnrc.yaml": false,
        "**/build": false,
        "**/node_modules": false,
        "**/prettier.config.mjs": false,
        "**/turbo.json": false,
        "**/yarn.lock": false
    },

    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/*/**": true
    },

    "search.followSymlinks": true,

    "search.exclude": {
        "**/node_modules": true,
        "**/.git": true
    }
}
