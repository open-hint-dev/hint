{
    "$schema": "https://turbo.build/schema.json",
    "globalEnv": ["VERSION"],
    "tasks": {
        "clean": {
            "dependsOn": ["^clean"]
        },
        "coverage": {
            "dependsOn": ["^coverage"]
        },
        "fix": {
            "dependsOn": ["^fix"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "publish": {
            "dependsOn": ["release", "^publish"],
            "cache": false
        },
        "refresh": {
            "dependsOn": ["^refresh"]
        },
        "release": {
            "dependsOn": ["^release"]
        },
        "test": {
            "dependsOn": ["^test"]
        }
    }
}
